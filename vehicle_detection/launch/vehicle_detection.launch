<launch>
  <!-- Play rosbag -->
  <node pkg="rosbag" type="play" name="bag_play" args="$(arg bag_file)" output="screen">
    <param name="loop" value="false"/>
  </node>

  <!-- Detection node -->
  <node pkg="vehicle_detection" type="detector_node" name="vehicle_detector" output="screen"/>

  <!-- Optional: image viewer -->
  <node pkg="image_view" type="image_view" name="view_detection"
        args="image:=/vehicle_detection/output"/>
</launch>

